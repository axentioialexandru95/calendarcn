      "dependencies": [
        "@dnd-kit/core@^6.3.1",
        "@dnd-kit/utilities@^3.2.2",
        "@phosphor-icons/react@^2.1.10",
        "date-fns@^4.1.0"
      ],
      "files": [
        {
          "path": "components/calendar/index.ts",
          "type": "registry:component"
        },
        {
          "path": "components/calendar/types.ts",
          "type": "registry:component"
        },
        {
          "path": "components/calendar/utils.ts",
          "type": "registry:component"
        },
        {
          "path": "components/calendar/internal/elements/root.tsx",
          "type": "registry:component"
        },
        {
          "path": "components/calendar/internal/elements/toolbar.tsx",
          "type": "registry:component"
        },
        {
          "path": "components/calendar/internal/elements/time-grid-view.tsx",
          "type": "registry:component"
        },
        {
          "path": "components/calendar/internal/elements/month-view.tsx",
          "type": "registry:component"
        },
        {
          "path": "components/calendar/internal/elements/agenda-view.tsx",
          "type": "registry:component"
        },
        {
          "path": "components/calendar/internal/elements/event-card.tsx",
          "type": "registry:component"
        },
        {
          "path": "components/calendar/internal/elements/event-context-menu.tsx",
          "type": "registry:component"
        },
        {
          "path": "components/calendar/internal/elements/event-change-confirmation-dialog.tsx",
