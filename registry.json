        },
        {
          "path": "components/calendar/internal/elements/event-create-sheet.tsx",
          "type": "registry:component"
        },
        {
          "path": "components/calendar/internal/shared.ts",
          "type": "registry:component"
        }
      ],
      "docs": "Build the registry with `pnpm registry:build`, then install locally with `npx shadcn@latest add ./public/r/calendarcn.json` or host `/r/calendarcn.json` and add it by URL. Import `CalendarRoot` from `@/components/calendar`."
    }
  ]
